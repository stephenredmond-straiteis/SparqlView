    ldont:capitalOf <http://localdata/country/ireland> ;
    ldont:locatedIn <http://localdata/country/ireland> ;
    ldont:population 1263219 ;
    ldont:foundedYear 841 ;
    geo:lat "53.3498"^^xsd:float ;
    geo:long "-6.2603"^^xsd:float ;
    owl:sameAs <http://dbpedia.org/resource/Dublin> .

