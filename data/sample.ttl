# Projects
<http://localdata/project/linked-cities> a ldont:Project ;
    rdfs:label "Linked Cities Initiative"@en ;
    dc:title "Linked Cities Initiative" ;
    dct:description "A project to interlink open data from European capital cities"@en ;
    ldont:relatedTo <http://localdata/city/dublin> ;
    ldont:relatedTo <http://localdata/city/paris> ;
    ldont:relatedTo <http://localdata/city/berlin> .

<http://localdata/project/open-data-eu> a ldont:Project ;
    rdfs:label "Open Data Europe"@en ;
    dc:title "Open Data Europe" ;
    dct:description "Pan-European open data publishing and linking initiative"@en ;
    ldont:relatedTo <http://localdata/country/france> ;
    ldont:relatedTo <http://localdata/country/germany> ;
    ldont:relatedTo <http://localdata/country/ireland> .

<http://localdata/project/semantic-ireland> a ldont:Project ;
    rdfs:label "Semantic Ireland"@en ;
    dc:title "Semantic Ireland" ;
    dct:description "Linking Irish public sector data using semantic web technologies"@en ;
    ldont:relatedTo <http://localdata/country/ireland> ;
    ldont:relatedTo <http://localdata/city/dublin> ;
    ldont:relatedTo <http://localdata/city/cork> ;
    ldont:relatedTo <http://localdata/city/galway> .
