@prefix ldont: <http://localdata/ontology/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix geo: <http://www.w3.org/2003/01/geo/wgs84_pos#> .

# Ontology definitions
ldont:Country a owl:Class ;
    rdfs:label "Country"@en ;
    rdfs:comment "A sovereign nation or state"@en .

ldont:City a owl:Class ;
    rdfs:label "City"@en ;
    rdfs:comment "A large human settlement"@en .

ldont:Person a owl:Class ;
    rdfs:label "Person"@en ;
    rdfs:comment "A human being"@en .

ldont:Organisation a owl:Class ;
    rdfs:label "Organisation"@en ;
    rdfs:comment "A structured group of people"@en .

ldont:Project a owl:Class ;
    rdfs:label "Project"@en ;
    rdfs:comment "A planned undertaking"@en .

ldont:capitalOf a owl:ObjectProperty ;
    rdfs:label "capital of"@en ;
    rdfs:domain ldont:City ;
    rdfs:range ldont:Country .

ldont:locatedIn a owl:ObjectProperty ;
    rdfs:label "located in"@en ;
    rdfs:domain ldont:City ;
    rdfs:range ldont:Country .

ldont:population a owl:DatatypeProperty ;
    rdfs:label "population"@en ;
    rdfs:range xsd:integer .

ldont:foundedYear a owl:DatatypeProperty ;
    rdfs:label "founded year"@en ;
    rdfs:range xsd:integer .

ldont:worksFor a owl:ObjectProperty ;
    rdfs:label "works for"@en ;
    rdfs:domain ldont:Person ;
    rdfs:range ldont:Organisation .

ldont:headquarteredIn a owl:ObjectProperty ;
    rdfs:label "headquartered in"@en ;
    rdfs:domain ldont:Organisation ;
    rdfs:range ldont:City .

ldont:involvedIn a owl:ObjectProperty ;
    rdfs:label "involved in"@en ;
    rdfs:domain ldont:Person ;
    rdfs:range ldont:Project .

ldont:relatedTo a owl:ObjectProperty ;
    rdfs:label "related to"@en .

# Countries
<http://localdata/country/ireland> a ldont:Country ;
    rdfs:label "Ireland"@en ;
    rdfs:label "Éire"@ga ;
    dc:title "Ireland" ;
    ldont:population 5123536 ;
    foaf:page <https://en.wikipedia.org/wiki/Republic_of_Ireland> ;
    owl:sameAs <http://dbpedia.org/resource/Republic_of_Ireland> .

<http://localdata/country/france> a ldont:Country ;
    rdfs:label "France"@en ;
    rdfs:label "France"@fr ;
    dc:title "France" ;
    ldont:population 67750000 ;
    foaf:page <https://en.wikipedia.org/wiki/France> ;
    owl:sameAs <http://dbpedia.org/resource/France> .

<http://localdata/country/germany> a ldont:Country ;
    rdfs:label "Germany"@en ;
    rdfs:label "Deutschland"@de ;
    dc:title "Germany" ;
    ldont:population 84482000 ;
    foaf:page <https://en.wikipedia.org/wiki/Germany> ;
    owl:sameAs <http://dbpedia.org/resource/Germany> .

<http://localdata/country/spain> a ldont:Country ;
    rdfs:label "Spain"@en ;
    rdfs:label "España"@es ;
    dc:title "Spain" ;
    ldont:population 47780000 ;
    owl:sameAs <http://dbpedia.org/resource/Spain> .

<http://localdata/country/italy> a ldont:Country ;
    rdfs:label "Italy"@en ;
    rdfs:label "Italia"@it ;
    dc:title "Italy" ;
    ldont:population 58850000 ;
    owl:sameAs <http://dbpedia.org/resource/Italy> .

# Cities
<http://localdata/city/dublin> a ldont:City ;
